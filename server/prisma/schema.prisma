generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BusinessType {
  RESTAURANT
  CAFE
  TEA_SHOP
  BAKERY
  FAST_FOOD
  CANTEEN
  OTHER
}

enum OrderMode {
  QR
  MANUAL
  BOTH
}

enum UserRole {
  OWNER
  STAFF
}

enum SourceType {
  TABLE
  COUNTER
  TAKEAWAY
  PARCEL
}

enum OrderType {
  QR
  MANUAL
}

enum OrderStatus {
  NEW
  ACCEPTED
  PREPARING
  READY
  SERVED
  PAID
  CANCELLED
}

model Business {
  id            String            @id @default(uuid()) @db.Uuid
  name          String            @db.VarChar(120)
  slug          String            @unique @db.VarChar(80)
  businessType  BusinessType      @map("business_type")
  ownerName     String            @map("owner_name") @db.VarChar(120)
  email         String            @db.VarChar(255)
  phone         String            @db.VarChar(32)
  logoUrl       String?           @map("logo_url") @db.Text
  currency      String            @default("INR") @db.VarChar(3)
  orderMode     OrderMode         @default(BOTH) @map("order_mode")
  isActive      Boolean           @default(true) @map("is_active")
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  users         User[]
  categories    Category[]
  menuItems     MenuItem[]
  orderSources  OrderSource[]
  orders        Order[]
  orderItems    OrderItem[]
  settings      BusinessSettings?
  authSessions  AuthSession[]

  @@index([isActive], map: "businesses_is_active_idx")
  @@map("businesses")
}

model User {
  id             String        @id @default(uuid()) @db.Uuid
  businessId     String        @map("business_id") @db.Uuid
  name           String        @db.VarChar(120)
  email          String        @db.VarChar(255)
  passwordHash   String        @map("password_hash") @db.VarChar(255)
  role           UserRole
  isActive       Boolean       @default(true) @map("is_active")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  business       Business      @relation(fields: [businessId], references: [id], onDelete: Restrict)
  placedOrders   Order[]       @relation("OrderPlacedByUser")
  authSessions   AuthSession[]

  @@unique([businessId, email], map: "users_business_id_email_key")
  @@unique([id, businessId], map: "users_id_business_id_key")
  @@index([businessId, role], map: "users_business_id_role_idx")
  @@index([businessId, isActive], map: "users_business_id_is_active_idx")
  @@map("users")
}

model Category {
  id          String     @id @default(uuid()) @db.Uuid
  businessId  String     @map("business_id") @db.Uuid
  name        String     @db.VarChar(120)
  sortOrder   Int        @default(0) @map("sort_order")
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  business    Business   @relation(fields: [businessId], references: [id], onDelete: Restrict)
  menuItems   MenuItem[]

  @@unique([id, businessId], map: "categories_id_business_id_key")
  @@index([businessId, isActive, sortOrder], map: "categories_business_id_is_active_sort_order_idx")
  @@map("categories")
}

model MenuItem {
  id            String      @id @default(uuid()) @db.Uuid
  businessId    String      @map("business_id") @db.Uuid
  categoryId    String      @map("category_id") @db.Uuid
  name          String      @db.VarChar(140)
  description   String?     @db.Text
  price         Decimal     @db.Decimal(12, 2)
  imageUrl      String?     @map("image_url") @db.Text
  isAvailable   Boolean     @default(true) @map("is_available")
  isVeg         Boolean     @default(false) @map("is_veg")
  sortOrder     Int         @default(0) @map("sort_order")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  business      Business    @relation(fields: [businessId], references: [id], onDelete: Restrict)
  category      Category    @relation(fields: [categoryId, businessId], references: [id, businessId], onDelete: Restrict)
  orderItems    OrderItem[]

  @@unique([id, businessId], map: "menu_items_id_business_id_key")
  @@index([businessId, categoryId, isAvailable], map: "menu_items_business_id_category_id_is_available_idx")
  @@index([businessId, sortOrder], map: "menu_items_business_id_sort_order_idx")
  @@map("menu_items")
}

model OrderSource {
  id          String      @id @default(uuid()) @db.Uuid
  businessId  String      @map("business_id") @db.Uuid
  sourceType  SourceType  @map("source_type")
  name        String      @db.VarChar(120)
  slug        String      @db.VarChar(80)
  qrUrl       String?     @map("qr_url") @db.Text
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  business    Business    @relation(fields: [businessId], references: [id], onDelete: Restrict)
  orders      Order[]

  @@unique([id, businessId], map: "order_sources_id_business_id_key")
  @@unique([businessId, slug], map: "order_sources_business_id_slug_key")
  @@index([businessId, sourceType, isActive], map: "order_sources_business_id_source_type_is_active_idx")
  @@map("order_sources")
}

model Order {
  id              String       @id @default(uuid()) @db.Uuid
  businessId      String       @map("business_id") @db.Uuid
  orderSourceId   String       @map("order_source_id") @db.Uuid
  orderType       OrderType    @map("order_type")
  status          OrderStatus  @default(NEW)
  subtotal        Decimal      @db.Decimal(12, 2)
  taxAmount       Decimal      @default(0) @map("tax_amount") @db.Decimal(12, 2)
  discountAmount  Decimal      @default(0) @map("discount_amount") @db.Decimal(12, 2)
  total           Decimal      @db.Decimal(12, 2)
  customerNote    String?      @map("customer_note") @db.Text
  placedByUserId  String?      @map("placed_by_user_id") @db.Uuid
  placedAt        DateTime     @default(now()) @map("placed_at") @db.Timestamptz(6)
  paidAt          DateTime?    @map("paid_at") @db.Timestamptz(6)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  business        Business     @relation(fields: [businessId], references: [id], onDelete: Restrict)
  orderSource     OrderSource  @relation(fields: [orderSourceId, businessId], references: [id, businessId], onDelete: Restrict)
  placedByUser    User?        @relation("OrderPlacedByUser", fields: [placedByUserId, businessId], references: [id, businessId], onDelete: Restrict)
  items           OrderItem[]

  @@unique([id, businessId], map: "orders_id_business_id_key")
  @@index([businessId, status, placedAt(sort: Desc)], map: "orders_business_id_status_placed_at_idx")
  @@index([businessId, orderSourceId, placedAt(sort: Desc)], map: "orders_business_id_order_source_id_placed_at_idx")
  @@index([businessId, paidAt(sort: Desc)], map: "orders_business_id_paid_at_idx")
  @@index([businessId, placedAt(sort: Desc)], map: "orders_business_id_placed_at_idx")
  @@map("orders")
}

model OrderItem {
  id                 String     @id @default(uuid()) @db.Uuid
  businessId         String     @map("business_id") @db.Uuid
  orderId            String     @map("order_id") @db.Uuid
  menuItemId         String     @map("menu_item_id") @db.Uuid
  itemNameSnapshot   String     @map("item_name_snapshot") @db.VarChar(140)
  itemPriceSnapshot  Decimal    @map("item_price_snapshot") @db.Decimal(12, 2)
  quantity           Int
  itemNote           String?    @map("item_note") @db.Text
  lineTotal          Decimal    @map("line_total") @db.Decimal(12, 2)
  createdAt          DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  business           Business   @relation(fields: [businessId], references: [id], onDelete: Restrict)
  order              Order      @relation(fields: [orderId, businessId], references: [id, businessId], onDelete: Cascade)
  menuItem           MenuItem   @relation(fields: [menuItemId, businessId], references: [id, businessId], onDelete: Restrict)

  @@unique([id, businessId], map: "order_items_id_business_id_key")
  @@index([businessId, orderId], map: "order_items_business_id_order_id_idx")
  @@index([businessId, menuItemId], map: "order_items_business_id_menu_item_id_idx")
  @@map("order_items")
}

model BusinessSettings {
  id                   String     @id @default(uuid()) @db.Uuid
  businessId           String     @unique @map("business_id") @db.Uuid
  acceptingOrders      Boolean    @default(true) @map("accepting_orders")
  showImages           Boolean    @default(true) @map("show_images")
  showItemDescription  Boolean    @default(true) @map("show_item_description")
  showVegBadge         Boolean    @default(true) @map("show_veg_badge")
  timezone             String     @default("UTC") @db.VarChar(64)
  createdAt            DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  business             Business   @relation(fields: [businessId], references: [id], onDelete: Restrict)

  @@map("business_settings")
}

model AuthSession {
  id                  String        @id @default(uuid()) @db.Uuid
  businessId          String        @map("business_id") @db.Uuid
  userId              String        @map("user_id") @db.Uuid
  refreshTokenHash    String        @unique @map("refresh_token_hash") @db.VarChar(255)
  userAgent           String?       @map("user_agent") @db.VarChar(512)
  ipAddress           String?       @map("ip_address") @db.VarChar(64)
  expiresAt           DateTime      @map("expires_at") @db.Timestamptz(6)
  lastUsedAt          DateTime?     @map("last_used_at") @db.Timestamptz(6)
  revokedAt           DateTime?     @map("revoked_at") @db.Timestamptz(6)
  replacedBySessionId String?       @map("replaced_by_session_id") @db.Uuid
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  business            Business      @relation(fields: [businessId], references: [id], onDelete: Restrict)
  user                User          @relation(fields: [userId, businessId], references: [id, businessId], onDelete: Restrict)
  replacedBySession   AuthSession?  @relation("SessionRotation", fields: [replacedBySessionId], references: [id], onDelete: SetNull)
  previousSessions    AuthSession[] @relation("SessionRotation")

  @@unique([id, businessId], map: "auth_sessions_id_business_id_key")
  @@index([businessId, userId], map: "auth_sessions_business_id_user_id_idx")
  @@index([businessId, revokedAt], map: "auth_sessions_business_id_revoked_at_idx")
  @@index([expiresAt], map: "auth_sessions_expires_at_idx")
  @@map("auth_sessions")
}
